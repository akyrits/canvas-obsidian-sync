# Canvas -> Calendar -> "Calendar Feed" link (Account > Settings also has it).
# Treat this like a password: anyone with this URL can read your Canvas calendar.
CANVAS_ICS_URL=https://fau.instructure.com/feeds/calendars/user_XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX.ics

# Absolute path to your Obsidian vault's root folder.
VAULT_PATH=C:/Users/kyrit/ObsidianVault

# Both paths below are relative to VAULT_PATH.
BOARD_RELATIVE_PATH=Boards/Assignments.md
ASSIGNMENTS_RELATIVE_DIR=School

# An assignment due within this many days lands in "This Week" instead of "Backlog".
DUE_SOON_DAYS=7

# Your own Anthropic API key (console.anthropic.com) - only needed for agent.py
# (setup-course / prep / ask). sync.py never reads this.
ANTHROPIC_API_KEY=sk-ant-XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX

# Optional - connect `agent.py ask` to a running LifeOS MCP server so it can
# reason over your live schedule alongside vault coursework. Both must be set
# to enable it; leave them out and `ask` stays vault-only. The token is
# LifeOS's LIFEOS_MCP_TOKEN. Treat it like a password: it reads all your tasks.
LIFEOS_MCP_URL=https://your-lifeos-host/api/mcp
LIFEOS_MCP_TOKEN=
